{
  "name": "kibi",
  "version": "0.1.4",
  "private": false,
  "license": "AGPL-3.0-or-later",
  "author": "Piotr Franczyk",
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "bun test",
    "test:unit": "bun test packages/",
    "test:e2e": "./scripts/docker/test.sh e2e",
    "test:e2e:compile": "tsc -p documentation/tests/e2e/packed/tsconfig.e2e.json",
    "test:e2e:local": "npm run test:e2e:compile && NODE_OPTIONS='--enable-source-maps' node --test --test-concurrency=1 documentation/tests/e2e/packed/dist/*.test.js",
    "test:docker": "./scripts/docker/test.sh",
    "docker:build": "docker compose -f docker/compose.test.yml build",
    "docker:clean": "docker compose -f docker/compose.test.yml down -v --remove-orphans",
    "pack:all": "npm pack --workspace packages/core && npm pack --workspace packages/cli && npm pack --workspace packages/mcp",
    "check": "biome check .",
    "format": "biome format --write .",
    "pack:drive": "./scripts/pack-to-drive.sh",
    "build:cli": "bun --filter ./packages/cli build",
    "build:mcp": "bun --filter ./packages/mcp build",
    "build": "bun run build:cli && bun run build:mcp",
    "publish:selective": "./scripts/publish-selective.sh",
    "release:npm": "bun run build && ./scripts/publish-selective.sh",
    "release:bun": "bun run build && ./scripts/publish-selective.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.2.3",
    "ajv-formats": "2.1.1",
    "bun-types": "^1.2.0",
    "mitata": "^1.0.34",
    "typescript": "^5.7.0"
  }
}

{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@kibi/cli/*": ["../../cli/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*test*", "node_modules", "dist"]
}

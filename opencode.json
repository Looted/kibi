{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "kibi": {
      "type": "local",
      "command": ["bun", "run", "packages/mcp/bin/kibi-mcp"],
      "enabled": true
    }
  },
  "lsp": {
    "prolog": {
      "command": [
        "swipl",
        "-g",
        "use_module(library(lsp_server)).",
        "-g",
        "lsp_server:main",
        "-t",
        "halt",
        "--",
        "stdio"
      ],
      "extensions": [".pl", ".prolog", ".plt"]
    }
  }
}
